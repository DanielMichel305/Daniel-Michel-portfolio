{
  "scripts": {
    "serve": "node ./dist/app.js",
    "build:server": "npm --prefix src/server run build",
    "build-prod": "npm install && npm audit fix && npx tsc && cp -a ./src/server/Views/. ./dist/server/Views/",
    "dev:server": "npm --prefix src/server run dev",
    "dev": "concurrently \"npm:dev:*\" ",
    "build": "npm run build:server && npm run build:client",
    "start": "node ./dist/server/app.js"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  },
  "workspaces": [
    "src/server"
  ],
  "dependencies": {
    "@sequelize/core": "^7.0.0-alpha.48",
    "@sequelize/sqlite3": "^7.0.0-alpha.48",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "isomorphic-dompurify": "^3.14.0",
    "marked": "^18.0.4"
  },
  "overrides": {
    "tar": "^7.5.11",
    "uuid": "13.0.1",
    "@tootallnate/once": "^2.0.1"
  }
}
